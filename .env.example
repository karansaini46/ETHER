# ETHER Environment Configuration

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# GitHub API — required for repository analysis
# Create a personal access token at https://github.com/settings/tokens
GITHUB_TOKEN=

# AI Navigator — optional, enables the AI chat feature
# Supported: gemini (default)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# GitHub OAuth — optional, enables private repository access
# Register an OAuth app at https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# SESSION_SECRET=
